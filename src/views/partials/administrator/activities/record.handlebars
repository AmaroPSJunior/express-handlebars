{{> h}}

<div class="content">
    <!-- START JUMBOTRON -->
    <div class="jumbotron" data-pages="parallax">
        <div class=" container-fluid container-fixed-lg sm-p-l-0 sm-p-r-0">
            <div class="inner">
                <!-- START BREADCRUMB -->
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">Administrador</a></li>
                    <li class="breadcrumb-item"><a href="#">Painel de Controle</a></li>
                    <li class="breadcrumb-item"><a href="#">Atividades</a></li>
                    <li class="breadcrumb-item active">Formulário</li>
                </ol>
                <!-- END BREADCRUMB -->
            </div>
        </div>
    </div>
    <!-- END JUMBOTRON -->
    <!-- START CONTAINER FLUID -->
    <div class="container-fluid container-fixed-lg">
        <!-- BEGIN PlACE PAGE CONTENT HERE -->

        {{> h}}

            <div class="row">
                <div class="col-lg-12">
                    <!-- START card -->
                    <div class="card card-default">
                        <div class="card-header ">
                            <div class="card-title">
                                Formulário de Atividade
                            </div>
                        </div>
                        <div class="card-body">

                            <h5>Atividade</h5>

                            <div class="row">
                                <div class="col-md-12">
                                    <div class=" form-group form-group-default form-group-default-select2 required">
                                        <label class="">Módulo</label>
                                        <select class="full-width" data-placeholder="Módulo" disabled
                                                data-init-plugin="select2" name="module">
                                            <optgroup label="Módulo">
                                                <option value="<?php echo (is_object($chapter)) ? $chapter->getModule()->getHash() : ''; ?>"
                                                        selected><?php echo (is_object($chapter)) ? $chapter->getModule()->getModule() : ''; ?></option>
                                            </optgroup>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class=" form-group form-group-default form-group-default-select2 required">
                                        <label class="">Conteúdo</label>
                                        <select class="full-width" data-placeholder="Capítulo" disabled
                                                data-init-plugin="select2" name="chapter">
                                            <optgroup label="Capítulo">
                                                <option value="<?php echo (is_object($chapter)) ? $chapter->getHash() : ''; ?>"
                                                        selected><?php echo (is_object($chapter)) ? $chapter->getChapter() : ''; ?></option>
                                            </optgroup>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <br>

                            <h5>Lista de Questões</h5>
                            <div class="progress progress_list">
                                <div class="progress-bar-indeterminate"></div>
                            </div>
                            <div id="list_questions"></div>

                            <br>

                            <h5>+ Questões</h5>
                            <div class="progress progress_question">
                                <div class="progress-bar-indeterminate"></div>
                            </div>
                            <div id="form_question"></div>

                        </div>

                    </div>
                    <!-- END card -->
                </div>
            </div>


        <!-- END PLACE PAGE CONTENT HERE -->
    </div>
    <!-- END CONTAINER FLUID -->
</div>

{{> f}}


<script>

    function list() {
        $('.progress_list').show();
        $.ajax({
            method: "GET",
            url: "<?php echo $route->pathFor('administrator.activities.get.chapter', ['hash' => $chapter->getHash()]);?>"
        })
            .done(function (html) {
                $('.progress_list').hide();
                $("#list_questions").html(html);
            });
    }

    function form(hash_activity = false) {
        $('.progress_question').show();
        var url = "<?php echo $route->pathFor('administrator.activities.post.chapter', ['hash' => $chapter->getHash()]);?>" + ((hash_activity) ? "/" + hash_activity : "");
        $.ajax({
            method: "POST",
            url: url
        })
            .done(function (html) {
                $('.progress_question').hide();
                $("#form_question").html(html);

                if ((hash_activity))
                    $(document).scrollTop($("#form_question").offset().top);

            });
    }

    $(document).ready(function () {

        list();
        form();

    })
</script>

