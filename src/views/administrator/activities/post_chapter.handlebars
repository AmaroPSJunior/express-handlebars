    </div>
</div>


<script>

    $(document).ready(function () {
        $('.clone').cloneya({
            serializeID: true,
            cloneButton: '.btns .btn-group .btn-group .clone',
            deleteButton: '.btns .btn-group .btn-group .delete',
            preserveChildCount: true
        })
            .on('before_clone.cloneya', function (event, toClone, newClone) {

                var o = $('#count_a').val();
                var n = eval(o) + 1;
                $('#count_a').val(n)

            })
            .on('after_append.cloneya', function (event, toClone, newClone) {
                var i = $('#count_a').val();
                $(newClone).find('.checkbox').val(i);
                $(newClone).find('.input_a').attr('name', "answer[" + i + "]");

            });


        $("#submit_activity").click(function () {

            $.ajax({
                method: "PUT",
                datType: 'JSON',
                url: "<?php echo $route->pathFor('administrator.activities.put.chapter'); ?>",
                data: $("#form_activity").serialize(),
                success: function (html) {

                    list();
                    form();
                },
                error: function () {

                }
            })

        });

        $('#editor').trumbowyg({
            btns: [
                ['strong', 'em'],
                ['justifyLeft', 'justifyCenter'],
                ['link']
            ]
        });


    })
</script>

