                                    Correto? <input type="checkbox"
                                                    name="correct"
                                                    value="<?php echo (is_object($answer)) ? $answer->getHash() : $x; ?>"
										<?php echo (($answer->getRight() == 1)) ? 'checked' : ''; ?> />
                                </div>
                                <div class="col-md-4 btns">
                                    <div class="btn-group btn-group-justified row w-100">
