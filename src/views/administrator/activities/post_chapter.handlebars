                                                <span class="fs-11 font-montserrat text-uppercase text-white">Remover</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
							<?php $x++;
						} ?>

					<?php } ?>

                    <input type="hidden" id="count_a" name="count_a" value="<?php echo $x; ?>">

                    <div class="row toclone class_anwsers">
                        <div class="col-md-6">
                            <div class="col-md-12 form-group form-group-default required" style="padding-left: 10px">
                                <label>Resposta</label>
                                <input name="answer[0]" type="text" class="form-control input_a" required>
                            </div>
                        </div>
                        <div class="col-md-2">
                            Correto? <input type="checkbox" class="checkbox" name="correct" value="0"/>
                        </div>
