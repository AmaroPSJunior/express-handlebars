        <form id="form_activity">
            <input type="hidden" name="hash_question"
                   value="<?php echo (is_object($question)) ? $question->getHash() : 0; ?>">
            <input type="hidden" name="hash_activity"
                   value="<?php echo (is_object($chapter)) ? $chapter->getActivities()->getHash() : 0; ?>">

            <div class="row" id="questions">
                <div class="col-md-12">
                    <div class="col-md-12 " style="padding-left: 10px;">
                        <h5>Enunciado</h5>
                        <div id="editor"><?php echo (is_object($question)) ? $question->getQuestion() : ''; ?></div>
                    </div>
                </div>
                <div class="clone col-12">
                    <h5>Respostas</h5>

					<?php $x = 0;
					if (is_object($question)) { ?>

						<?php foreach ($question->getAnswers() as $answer) { ?>
                            <div class="row toclone class_anwsers">

                                <div class="col-md-6">
                                    <div class="col-md-12 form-group form-group-default required"
                                         style="padding-left: 10px">
                                        <label>Resposta</label>
                                        <input name="answer[<?php echo (is_object($answer)) ? $answer->getHash() : ''; ?>]"
                                               type="text" class="form-control" required
                                               value="<?php echo $answer->getAnswer(); ?>">
                                    </div>
                                </div>
