                            <div class="btn-group btn-group-justified row w-100">
                                <div class="btn-group col-6 p-0">
                                    <a type="button " class="btn btn-warning w-100 clone">
                                        <span class="p-t-5 p-b-5 text-black"> <i
                                                    class="fa fa-plus fs-15"></i></span><br>
                                        <span class="fs-11 font-montserrat text-black text-uppercase">Adicionar</span>
