{{> f}}

<script>

    function g() {
        $('.progress').show();
        $.ajax({
            method: "POST",
            url: "<?php echo $route->pathFor('student.tickets.search');?>",
            data: $('#form_search').serialize()
        })
            .done(function (html) {
                $('.progress').hide();
                $("#result_coupon").html(html);
            });
    }

    $(document).ready(function () {

        $('#input-search').terminadedigitar(function () {
            g();
        }, 500);

    })

    g();


</script>

